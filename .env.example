# Postgres
DATABASE_URL=postgresql://jigit:jigit@localhost:5432/jigit

# Redis
REDIS_URL=redis://localhost:6379

# Encryption (32-byte base64 random string)
APP_ENCRYPTION_KEY=

# Agent concurrency
MAX_CONCURRENT_AGENTS=3
MAX_RETRIES=3
APPROVAL_TIMEOUT_MS=1800000
# Reject a single ACP request (e.g. session/prompt) if the subprocess never responds
ACP_REQUEST_TIMEOUT_MS=600000

# Anthropic (set ONE of these; ANTHROPIC_AUTH_TOKEN is preferred)
ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_API_KEY=        # legacy alias – also accepted
# ANTHROPIC_BASE_URL=       # optional: override API endpoint (e.g. a proxy)

# Telegram
TELEGRAM_BOT_TOKEN=

# Public URL (used for dashboard links in Telegram messages)
PUBLIC_BASE_URL=http://localhost:3000

# NestJS
API_PORT=3000
API_WEBHOOK_SECRET=

# Dashboard API token (used by dashboard client to authenticate with API)
DASHBOARD_API_TOKEN=

# ─── Agent session reporting (hook adapters; set on developer machines) ───────
# Consumed by the @jigit/hook-* adapters on each developer's machine, NOT by the
# API service. Listed here for reference.
# Base URL of the JiGit API the hooks POST session snapshots to.
JAGIT_BASE_URL=http://localhost:3000
# Shared API key for hooks (use the same value as DASHBOARD_API_TOKEN).
JAGIT_API_KEY=
# Optional: override the reporting identity (defaults to git config user.email).
# JAGIT_GIT_USERNAME=
